{
  "name": "instagram-automation",
  "private": true,
  "version": "0.1.0",
  "description": "Painel de automação de Stories e Reels do Instagram via AdsPower",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,worker,client -c blue,magenta,green \"npm run dev:server\" \"npm run dev:worker\" \"npm run dev:client\"",
    "dev:server": "npm --workspace server run dev",
    "dev:worker": "npm --workspace server run dev:worker",
    "dev:client": "npm --workspace client run dev",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:migrate": "npm --workspace server run db:migrate",
    "db:seed": "npm --workspace server run db:seed",
    "db:studio": "npm --workspace server run db:studio"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
