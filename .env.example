# ===== Modo de automação =====
# mock = simula AdsPower e Instagram (Etapa 1 e 2)
# real = usa AdsPower + Playwright (Etapa 3 - ainda não implementado)
AUTOMATION_MODE=mock

# ===== Banco de dados =====
DATABASE_URL="file:./dev.db"

# ===== Backend (Fastify) =====
PORT=3010
HOST=0.0.0.0
JWT_SECRET="trocar-em-producao-por-uma-string-longa-aleatoria"
CORS_ORIGIN="http://localhost:3000"

# ===== Admin bootstrap =====
# Senha gerada no primeiro start se vazia
ADMIN_EMAIL=admin@local
ADMIN_BOOTSTRAP_PASSWORD=admin123

# ===== Worker / fila =====
# máximo de perfis AdsPower abertos simultaneamente
MAX_CONCURRENT_PROFILES=3
# intervalo de poll do worker (ms)
WORKER_POLL_INTERVAL_MS=5000
# tentativas máximas por job antes de pausar a conta
MAX_JOB_ATTEMPTS=2

# ===== Mock driver (apenas dev/teste) =====
# 0 a 1 - taxa de falha simulada em postStory/postReel
AUTOMATION_MOCK_FAIL_RATE=0.1
# delay mínimo/máximo simulado por operação (ms)
AUTOMATION_MOCK_MIN_DELAY=2000
AUTOMATION_MOCK_MAX_DELAY=8000

# ===== Real driver (Etapa 3) =====
# AdsPower local API (porta padrão é 50325)
ADSPOWER_API_URL=http://localhost:50325

# ===== Frontend (Next.js) =====
NEXT_PUBLIC_API_URL=http://localhost:3010
