# ========================================================
# Modo de operacao
# mock = simula tudo, sem AdsPower (testes locais)
# real = usa AdsPower + Playwright (producao)
# ========================================================
AUTOMATION_MODE=mock

# Banco de dados (SQLite local)
DATABASE_URL="file:./dev.db"

# Servidor (porta da API)
PORT=3010
HOST=0.0.0.0
CORS_ORIGIN="http://localhost:3000"

# JWT - segredo pra autenticacao do painel
# (32 bytes aleatorios em hex - troque se for ambiente sensivel)
JWT_SECRET="6582031c0722e71926cb85ae29f066a428046396b40e01ea2e6e7240248c8c5e"

# Admin do painel
ADMIN_EMAIL=admin@local
ADMIN_BOOTSTRAP_PASSWORD=admin123

# Worker / fila
MAX_CONCURRENT_PROFILES=3
WORKER_POLL_INTERVAL_MS=5000
MAX_JOB_ATTEMPTS=2

# Mock driver (quando AUTOMATION_MODE=mock)
AUTOMATION_MOCK_FAIL_RATE=0.1
AUTOMATION_MOCK_MIN_DELAY=2000
AUTOMATION_MOCK_MAX_DELAY=8000

# AdsPower (quando AUTOMATION_MODE=real)
ADSPOWER_API_URL=http://local.adspower.net:50325
# Se sua versao do AdsPower exige API key, descomente:
# ADSPOWER_API_KEY=

# Playwright
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO_MS=0

NODE_ENV=development
